<div class="friends-area">
    <div class="friends-title">
        友情链接
        <i class="back-title-list"></i>
    </div>
    <div class="friends-content">
        <ul>
            <% for (var friend in theme.friends){ %>
                <% if(theme.friends[friend]){%>
                    <li><a target="_blank" href="<%- url_for(theme.friends[friend]) %>"><%=friend %></a></li>
                <%} else {%>
                    <li><a href="javascript:void(0);"><%=friend %></a></li>
                <%}%>
            <% } %>
        </ul>
    </div>
</div>